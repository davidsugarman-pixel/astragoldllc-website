  .escrow-steps { display: flex; flex-direction: column; gap: 16px; }
  .escrow-step { display: flex; gap: 16px; align-items: flex-start; }
  .step-num { background: var(--gold); color: var(--navy); font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 18px; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .step-text { color: rgba(255,255,255,0.85); font-size: 14px; line-height: 1.6; padding-top: 6px; }
  .step-text strong { color: var(--gold); }

  /* TESTIMONIALS */
  .testimonials-section { background: var(--off-white); padding: 64px; }
  .testimonials-section .section-title { text-align: center; margin-bottom: 40px; }
  .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .testimonial-card { background: var(--white); border-radius: 10px; padding: 28px 24px; box-shadow: 0 2px 16px rgba(10,22,40,0.07); display: flex; flex-direction: column; gap: 16px; }
  .testimonial-top { display: flex; align-items: center; gap: 14px; }
  .avatar-placeholder { width: 52px; height: 52px; border-radius: 50%; border: 3px solid var(--gold); background: linear-gradient(135deg, #1a3260, #2a4a8a); display: flex; align-items: center; justify-content: center; font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 20px; color: var(--gold); flex-shrink: 0; }
  .testimonial-name { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 17px; color: var(--text-dark); }
  .stars { color: var(--gold); font-size: 12px; letter-spacing: 1px; }
  .testimonial-text { font-size: 13.5px; color: var(--text-muted); line-height: 1.65; font-style: italic; }

  /* APPLY */
  .apply-section { background: var(--navy); padding: 64px; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .apply-section h2 { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 42px; text-transform: uppercase; color: var(--white); line-height: 1.1; margin-bottom: 16px; }
  .apply-section h2 span { color: var(--gold); }
  .apply-section > div > p { color: rgba(255,255,255,0.7); font-size: 15px; line-height: 1.65; margin-bottom: 28px; }
  .pay-breakdown { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 10px; padding: 28px; }
  .pay-row { display: flex; justify-content: space-between; align-items: center; padding: 11px 0; border-bottom: 1px solid rgba(255,255,255,0.08); font-size: 14px; color: rgba(255,255,255,0.8); }
  .pay-row:last-child { border-bottom: none; }
  .pay-row strong { color: var(--gold); font-size: 17px; font-family: 'Barlow Condensed', sans-serif; font-weight: 800; }
  .apply-form { background: var(--white); border-radius: 10px; padding: 36px; }
  .apply-form h3 { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 24px; color: var(--text-dark); text-transform: uppercase; margin-bottom: 24px; }
  .form-group { margin-bottom: 16px; }
  .form-group label { display: block; font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
  .form-group input, .form-group select { width: 100%; border: 1.5px solid var(--border); border-radius: 6px; padding: 11px 14px; font-family: 'Barlow', sans-serif; font-size: 14px; color: var(--text-dark); outline: none; transition: border-color 0.2s; background: var(--off-white); }
  .form-group input:focus, .form-group select:focus { border-color: var(--gold); background: var(--white); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .btn-gold-full { width: 100%; text-align: center; padding: 14px; font-size: 17px; }
  .form-status { display: none; padding: 14px; border-radius: 6px; text-align: center; font-weight: 600; margin-top: 12px; font-size: 14px; }
  .form-status.success { display: block; background: #d4edda; color: #155724; }
  .form-status.error { display: block; background: #f8d7da; color: #721c24; }
  .form-note { font-size: 12px; color: var(--text-muted); margin-top: 10px; text-align: center; }

  /* FOOTER */
  .contact-section { background: var(--navy); padding: 50px 64px; display: grid; grid-template-columns: 1fr 1fr 220px; gap: 40px; align-items: start; border-top: 1px solid rgba(255,255,255,0.08); }
  .contact-logo { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .contact-logo img { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(232,168,32,0.3); }
  .contact-info p, .contact-info a { font-size: 14px; color: rgba(255,255,255,0.65); line-height: 2.1; text-decoration: none; display: flex; align-items: center; gap: 8px; }
  .contact-info a:hover { color: var(--gold); }
  .contact-info h4 { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 15px; color: var(--gold); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 14px; }
  .contact-map { background: #1a2e50; border-radius: 8px; height: 160px; display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.4); font-size: 13px; flex-direction: column; gap: 8px; border: 1px solid rgba(255,255,255,0.07); }
  .footer-bottom { background: #060f1e; padding: 16px 64px; text-align: center; font-size: 12px; color: rgba(255,255,255,0.3); }

  /* FOOTER LOGO WATERMARK */
  .footer-logo-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 32px 0 24px;
    background: var(--navy);
    border-top: 1px solid rgba(232,168,32,0.12);
  }
  .footer-logo-center img { width: 70px; height: 70px; border-radius: 50%; object-fit: cover; opacity: 0.9; filter: drop-shadow(0 0 12px rgba(232,168,32,0.3)); }
  .footer-logo-center span { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 13px; color: rgba(232,168,32,0.5); letter-spacing: 3px; text-transform: uppercase; }

  @media (max-width: 900px) {
    .features-grid, .testimonials-grid, .apply-section, .contact-section, .escrow-section { grid-template-columns: 1fr; }
    .gallery-grid { grid-template-columns: 1fr 1fr; }
    .gallery-grid .wide { grid-column: span 1; }
    .hero-card { left: 50%; transform: translate(-50%, -50%); width: 92%; padding: 0; background: transparent; }
    .hero-card h1 { font-size: 38px; }
    .section, .testimonials-section, .apply-section, .gallery-section, .escrow-section { padding: 40px 20px; }
    .navbar { padding: 0 16px; }
    .nav-links a { padding: 7px 8px; font-size: 11px; }
    .hero-badge { display: none; }
    .contact-section { padding: 40px 20px; }
  }
</style>
</head>
