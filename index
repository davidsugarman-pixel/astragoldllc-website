  .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .gallery-grid img { width: 100%; height: 220px; object-fit: cover; border-radius: 8px; transition: transform 0.3s, box-shadow 0.3s; cursor: pointer; }
  .gallery-grid img:hover { transform: scale(1.02); box-shadow: 0 8px 30px rgba(0,0,0,0.18); }
  .gallery-grid .wide { grid-column: span 2; }

  /* ESCROW */
  .escrow-section { background: var(--navy); padding: 60px 64px; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .escrow-section h2 { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 36px; text-transform: uppercase; color: var(--white); line-height: 1.1; margin-bottom: 16px; }
